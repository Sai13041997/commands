name: OPA Policy Validation

on:
  workflow_call:
    inputs:
      tfplan-artifact:
        required: true
        type: string
    secrets:
      cross_repo_app_id:
        required: true
      cross_repo_key:
        required: true

jobs:
  validate:
    runs-on: ubuntu-24.04

    steps:
      - name: Get GitHub App Token
        id: app_token
        uses: actions/create-github-app-token@bcd2ba49218906704ab6c1aa796996da409d3eb1 # v3.2.0
        with:
          app-id: ${{ secrets.cross_repo_app_id }}
          private-key: ${{ secrets.cross_repo_key }}
          owner: ${{ github.repository_owner }}

      - name: Checkout OPA policy repo
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0
        with:
          repository: ${{ job.workflow_repository }}
          ref: ${{ job.workflow_sha }}
          token: ${{ steps.app_token.outputs.token }}
          path: opa-policy

      - name: Download tfplan artifact
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4.3.0
        with:
          name: ${{ inputs.tfplan-artifact }}
          path: .
      - name: Install OPA
        run: |
          curl -fsSL -o opa https://openpolicyagent.org/downloads/latest/opa_linux_amd64_static
          chmod +x opa
          sudo mv opa /usr/local/bin/opa

      - name: Run OPA validation
        shell: bash
        run: |
          set -euo pipefail

          RESULT=$(opa eval \
            --format=json \
            --data opa-policy/tags \
            --input tfplan.json \
            "data.terraform.tags.deny")

          COUNT=$(echo "$RESULT" | jq '(.result[0].expressions[0].value // []) | length')

          #PASS CASE
          if [ "$COUNT" -eq 0 ]; then
            echo "=================================================="
            echo "         OPA POLICY CHECK: PASSED"
            echo "=================================================="
            echo "All required tags are present on all resources."
            echo "=================================================="
            exit 0
          fi

          #FAIL CASE — extract details
          VIOLATIONS=$(echo "$RESULT" | jq -r '(.result[0].expressions[0].value // [])[]')

          UNIQUE_TAGS=$(echo "$VIOLATIONS" \
