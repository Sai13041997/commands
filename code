package terraform.tags

import rego.v1

# Read required tags from config
required_tags := data.configurations.required_tags

# Expanded non-taggable resources
non_taggable := {
  "aws_iam_policy_attachment",
  "aws_iam_role_policy",
  "aws_iam_role_policy_attachment",
  "aws_s3_bucket_policy",
  "aws_route_table_association",
  "aws_lambda_permission",
  "aws_api_gateway_deployment",
  "aws_api_gateway_method",
  "aws_api_gateway_integration",
  "aws_api_gateway_base_path_mapping",
  "aws_route53_record",
  "aws_acm_certificate_validation",
  "aws_s3_bucket_public_access_block",
  "aws_s3_bucket_versioning",
  "aws_lb_target_group_attachment",
  "aws_cloudwatch_event_target",
  "aws_ecs_cluster_capacity_providers",
  "terraform_data"
}

# Defensive: fail loud if config missing
deny contains msg if {
  not required_tags
  msg := "CONFIG ERROR: required_tags config not loaded"
}

# Rule 1 — Resource has no tags at all
deny contains msg if {
  resource := input.resource_changes[_]

  # Only check managed resources (skip data sources)
  resource.mode == "managed"

  not non_taggable[resource.type]
  resource.change.after != null

  tags := object.get(resource.change.after, "tags_all",
          object.get(resource.change.after, "tags", null))

  tags == null
  msg := sprintf("Resource %s has no tags", [resource.address])
}

# Rule 2 — Resource missing specific required tag
deny contains msg if {
  resource := input.resource_changes[_]

  # Only check managed resources (skip data sources)
  resource.mode == "managed"

  not non_taggable[resource.type]
  resource.change.after != null

  tags := object.get(resource.change.after, "tags_all", {})

  required := required_tags[_]
  not tags[required]

  msg := sprintf("Resource %s missing tag: %s", [resource.address, required])
}

