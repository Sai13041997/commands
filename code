variable "mtls_truststore_version" {
  type        = string
  description = "S3 object version ID of the mTLS truststore. Required when the truststore content is updated so AWS knows exactly which version to trust."
  default     = null
}



dynamic "mutual_tls_authentication" { 
  for_each = var.mtls_truststore_uri != null ? [1] : [] 
  content { 
    truststore_uri     = var.mtls_truststore_uri
    truststore_version = var.mtls_truststore_version
  } 
}


mtls_truststore_version = "PASTE_THE_VERSION_ID_HERE"



