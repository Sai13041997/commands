          echo "$UNIQUE_TAGS" | sed 's/^/   - /'
          echo ""
          echo "   Affected Resources:"
          echo "$AFFECTED_RESOURCES" | sed 's/^/   - /'
          echo ""
          echo "::group:: Detailed Violations"
          echo "$VIOLATIONS" | sed 's/^/   • /'
          echo "::endgroup::"
          echo "=================================================="
          echo "Fix: Add missing tags to resource tags blocks."
          echo "=================================================="

