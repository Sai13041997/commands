2. Write and deploy the infra Terraform. Two files:
envs/dev.tfvars — change:
hclserverless_v2_min_acu = 2   # was 1
lambda_warmer.tf — new file:
hclresource "aws_cloudwatch_event_rule" "soap_lambda_warmer" {
  name                = "${var.application_name}-${var.env_tier}-soap-lambda-warmer"
  description         = "Keeps SOAP verification Lambda warm to meet KIVS 2s SLA"
  schedule_expression = "rate(5 minutes)"
}

resource "aws_cloudwatch_event_target" "soap_lambda_warmer" {
  rule      = aws_cloudwatch_event_rule.soap_lambda_warmer.name
  target_id = "soap-verification-lambda"
  arn       = module.soap_verification_lambda.lambda_function_arn
  input     = jsonencode({ warmup = true })
}

resource "aws_lambda_permission" "allow_eventbridge_warmer" {
  statement_id  = "AllowEventBridgeWarmer"
  action        = "lambda:InvokeFunction"
  function_name = module.soap_verification_lambda.lambda_function_name
  principal     = "events.amazonaws.com"
  source_arn    = aws_cloudwatch_event_rule.soap_lambda_warmer.arn
}
